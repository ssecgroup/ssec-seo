{
  "version": 2,
  "functions": {
    "api/scan.py": {
      "maxDuration": 60,
      "memory": 1024,
      "runtime": "python3.9@1.0.0"
    }
  },
  "routes": [
    {
      "src": "/api/scan",
      "dest": "/api/scan.py"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
